{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    {
      "identifier": "fs:allow-write-file",
      "allow": [{ "path": "$TEMP/**" }]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [{ "path": "$TEMP/**" }]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [{ "path": "$TEMP/**" }]
    }
  ]
}
